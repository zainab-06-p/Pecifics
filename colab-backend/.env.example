# ================================================
# Pecifics / JARVIS LangChain Backend Config
# Copy this file to .env and fill in your values
# ================================================
#
# RECOMMENDED SETUP (no GPU, no ngrok, fully free):
#   1. Get free Groq key  → https://console.groq.com
#   2. Get free Gemini key → https://aistudio.google.com/app/apikey
#   Set LLM_PROVIDER=groq and VISION_PROVIDER=gemini below
# ================================================

# ── LLM Provider ──────────────────────────────
# Options: "groq" (default) | "openai" | "ollama" | "transformers"
LLM_PROVIDER=groq

# ── Vision Provider ───────────────────────────
# Options: "gemini" (default) | "openai" | "ollama" | "transformers"
VISION_PROVIDER=gemini

# ── Groq (used when LLM_PROVIDER=groq) ───────
# Free key → https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Gemini Vision (used when VISION_PROVIDER=gemini) ──
# Free key → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI (optional, used when LLM_PROVIDER=openai) ──
OPENAI_API_KEY=sk-...your_key_here...
OPENAI_MODEL=gpt-4o

# ── Ollama (used when LLM_PROVIDER=ollama) ────
# Ollama must be running locally
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Server ────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── ngrok (optional, only needed for remote access) ──
# Get free token at https://dashboard.ngrok.com
NGROK_TOKEN=your_ngrok_authtoken_here
USE_NGROK=false

# ── Session / Memory ─────────────────────────
# Max conversation turns to keep in memory per session
MAX_HISTORY_TURNS=10
# Auto-clear sessions older than N minutes
SESSION_TTL_MINUTES=60

# ── Retry / Fallback ─────────────────────────
# Max retries when an action fails
MAX_ACTION_RETRIES=3
# Seconds to wait between retries
RETRY_DELAY_SECONDS=1

# ── Safety ───────────────────────────────────
# Require explicit confirmation for destructive actions
REQUIRE_CONFIRMATION=true
# Log all planned actions to a file
ACTION_LOG_FILE=action_log.jsonl
